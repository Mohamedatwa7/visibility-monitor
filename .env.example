# ── Storage ───────────────────────────────────────────────────────────────
# If both are set, Supabase is used. Otherwise a local SQLite file
# (banner-monitor/data/banners.db) is used automatically — no config needed.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Email delivery ────────────────────────────────────────────────────────
# Preferred: Resend. If RESEND_API_KEY is set, it is used.
RESEND_API_KEY=

# Fallback: SMTP via Nodemailer (used when RESEND_API_KEY is empty).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# From address for alert emails (e.g. "Banner Monitor <alerts@yourdomain.com>")
ALERT_FROM=

# Default alert recipients (comma-separated). The dashboard can override these
# via PUT /api/recipients; this value seeds the list when none is stored yet.
ALERT_RECIPIENTS=

# Alert mode: "change" (any count change) or "drop" (only when count falls).
ALERT_ON=change

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000

# Timezone for the process (cron uses Asia/Dubai explicitly regardless).
TZ=Asia/Dubai
